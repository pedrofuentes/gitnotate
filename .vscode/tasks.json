{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-vscode-extension",
      "type": "shell",
      "command": "pnpm build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "watch-vscode-extension",
      "type": "shell",
      "command": "pnpm --filter @gitnotate/vscode-extension watch",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "group": "build",
      "problemMatcher": []
    }
  ]
}
