{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-vscode-extension",
      "type": "shell",
      "command": "pnpm --filter @gitnotate/core build && pnpm --filter gitnotate build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "watch-vscode-extension",
      "type": "shell",
      "command": "pnpm --filter gitnotate watch",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "group": "build",
      "problemMatcher": []
    }
  ]
}
