{
  "name": "gitnotate",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "audit": "pnpm audit",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,json,css,html}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitest/coverage-v8": "^3.2.6",
    "approve-builds": "^1.0.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": ">=7.0.5",
      "diff": ">=8.0.3",
      "lodash": "4.18.1",
      "vite": "6.4.2",
      "postcss": "8.5.10",
      "esbuild": ">=0.28.1"
    }
  }
