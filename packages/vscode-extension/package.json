{
  "name": "@gitnotate/vscode-extension",
  "displayName": "Gitnotate",
  "description": "Sub-line commenting for Markdown files in GitHub PR reviews",
  "version": "0.0.1",
  "publisher": "pedrofuentes",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:markdown",
    "onView:gitnotate"
  ],
  "contributes": {
    "commands": [
      {
        "command": "gitnotate.enable",
        "title": "Gitnotate: Enable for Workspace"
      },
      {
        "command": "gitnotate.disable",
        "title": "Gitnotate: Disable for Workspace"
      },
      {
        "command": "gitnotate.addComment",
        "title": "Gitnotate: Add Comment"
      },
      {
        "command": "gitnotate.refreshComments",
        "title": "Refresh Comments",
        "icon": "$(refresh)"
      },
      {
        "command": "gitnotate.goToComment",
        "title": "Go to Comment"
      },
      {
        "command": "gitnotate.resolveThread",
        "title": "Resolve Thread",
        "icon": "$(check)"
      },
      {
        "command": "gitnotate.unresolveThread",
        "title": "Unresolve Thread",
        "icon": "$(circle-slash)"
      },
      {
        "command": "gitnotate.replyToThread",
        "title": "Reply",
        "enablement": "!commentIsEmpty",
        "icon": "$(reply)"
      }
    ],
    "configuration": {
      "title": "Gitnotate",
      "properties": {
        "gitnotate.enabledRepos": {
          "type": "array",
          "default": [],
          "description": "List of repository paths where Gitnotate is enabled",
          "items": {
            "type": "string"
          }
        },
        "gitnotate.pollInterval": {
          "type": "number",
          "default": 30,
          "minimum": 10,
          "description": "Polling interval in seconds for live comment updates from GitHub"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitnotate",
          "title": "Gitnotate",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "gitnotate": [
        {
          "id": "gitnotateComments",
          "name": "Comments"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "gitnotate.refreshComments",
          "when": "view == gitnotateComments",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "gitnotate.replyToThread",
          "when": "false"
        },
        {
          "command": "gitnotate.resolveThread",
          "when": "false"
        },
        {
          "command": "gitnotate.unresolveThread",
          "when": "false"
        },
        {
          "command": "gitnotate.goToComment",
          "when": "false"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "gitnotate.replyToThread",
          "group": "inline",
          "when": "commentController == gitnotate && !commentThreadIsEmpty"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "gitnotate.resolveThread",
          "group": "inline",
          "when": "commentController == gitnotate && commentThread.state == 0"
        },
        {
          "command": "gitnotate.unresolveThread",
          "group": "inline",
          "when": "commentController == gitnotate && commentThread.state == 1"
        }
      ],
      "editor/context": [
        {
          "command": "gitnotate.addComment",
          "when": "editorHasSelection && resourceLangId == markdown && gitnotate.hasPR",
          "group": "gitnotate@1"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "pnpm build --watch",
    "test": "vitest run",
    "test:integration:compile": "tsc -p tsconfig.integration.json",
    "test:integration": "pnpm test:integration:compile && vscode-test",
    "lint": "eslint src/",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@gitnotate/core": "workspace:*"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.0",
    "mocha": "^11.7.5"
  }
}
